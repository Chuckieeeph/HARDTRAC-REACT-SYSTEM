PORT=4000
NODE_ENV=development

# MySQL (Laragon default is usually user=root with empty password)
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=hardtrac_db

# JWT
JWT_SECRET=change_me_in_production
JWT_EXPIRES_IN=8h

# Frontend dev server origin (Vite)
CORS_ORIGIN=http://localhost:5173

