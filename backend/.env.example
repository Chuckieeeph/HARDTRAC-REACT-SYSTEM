PORT=4000
NODE_ENV=development

# MySQL (Laragon default is usually user=root with empty password)
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=hardtrac_db_backup2

# JWT
JWT_SECRET=change_me_in_production
JWT_EXPIRES_IN=8h

# Frontend dev server origin (Vite)
CORS_ORIGIN=http://localhost:5173

# Brute-force protection (login)
# If running behind a reverse proxy/load balancer that sets X-Forwarded-For,
# set TRUST_PROXY=true so the backend uses the left-most forwarded IP.
TRUST_PROXY=false
LOGIN_MAX_ATTEMPTS=8
LOGIN_WINDOW_SEC=60
LOGIN_LOCK_SEC=600
